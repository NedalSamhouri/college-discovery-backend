# Get this from your Neon dashboard: Project -> Connection string -> "Pooled connection"
# Used by your running app (src/lib/prisma.ts) for normal queries.
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"

# Neon also gives you a "Direct connection" (no -pooler in the hostname).
# Used by the Prisma CLI (prisma.config.ts) for migrations and seeding.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"
